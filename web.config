<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <add name="Python FastCGI"
           path="*"
           verb="*"
           modules="FastCgiModule"
           scriptProcessor="C:\Users\bankappadmin\AppData\Local\Programs\Python\Python312\python.exe|C:\Users\bankappadmin\AppData\Local\Programs\Python\Python312\Scripts\wfastcgi.exe"
           resourceType="Unspecified"
           requireAccess="Script" />
    </handlers>

    <fastCgi>
      <application fullPath="C:\Users\bankappadmin\AppData\Local\Programs\Python\Python312\python.exe"
                   arguments="C:\Users\bankappadmin\AppData\Local\Programs\Python\Python312\Scripts\wfastcgi.exe"
                   maxInstances="4" />
    </fastCgi>

  </system.webServer>
</configuration>